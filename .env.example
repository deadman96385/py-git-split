# git-split configuration
# Copy this file to .env and fill in your values

# Anthropic API key (required)
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI API key (optional)
# Enables Stage 5 embedding refinement for ambiguous bundles via voyage-code-3
# Get one at https://dash.voyageai.com/
VOYAGE_API_KEY=

# Interactive review behavior (optional)
# true  -> skip prompts and auto-accept groups
# false -> keep interactive review loop (default)
GIT_SPLIT_AUTO_ACCEPT=false
